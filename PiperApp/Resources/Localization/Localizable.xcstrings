    "app_help_line_1" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Select **Install Voice Model** at the bottom of the main screen."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натисніть **Встановити голосову модель** внизу головного екрану."
          }
        }
      }
    },
    "app_help_line_2_ios" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Go to **Settings → Accessibility → VoiceOver → Speech**."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перейдіть до **Налаштування → Доступність → VoiceOver → Мова**."
          }
        }
      }
    },
    "app_help_line_2_macos" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Open **VoiceOver Utility → Speech**."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Відкрийте **VoiceOver Utility → Мова**."
          }
        }
      }
    },
    "app_help_line_3_ios" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap **Add Rotor Voice**, find the voice you installed under **Piper**, and select it."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Натисніть **Додати голос ротора**, знайдіть встановлений голос у розділі **Piper** та виберіть його."
          }
        }
      }
    },
    "app_help_line_3_macos" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Click **Add**, then select the installed voice."
