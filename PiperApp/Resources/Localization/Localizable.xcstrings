    "about_app" : {
      "comment" : "A label for the \"About\" button in the main view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "About the App"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O aplikacji"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygulama Hakkında"
          }
        },
        "uk" : {
