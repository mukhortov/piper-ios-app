    "license_main_app_description" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piper App, developed by [Ihor Shevchuk](https://ihor-shevchuk.dev), is licensed under MIT. It is a separate program and communicates with the Audio Unit Extension only via XPC."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Piper App, розроблений [Ігорем Шевчуком](https://ihor-shevchuk.dev), ліцензований за MIT. Це окрема програма, яка взаємодіє з Audio Unit Extension лише через XPC."
          }
        }
